# Copy this file to .env in the project root before running Docker Compose.
# Do not commit .env.

DB_HOST=db
DB_PORT=5432
DB_NAME=soboksobok
DB_USER=edu
DB_PASSWORD=change-me

CRAWL_INTERVAL_SECONDS=86400
SBIZ24_PAGE_SIZE=100
SBIZ24_REQUEST_DELAY_SECONDS=1.0
SEMAS_SEED_URL=https://www.semas.or.kr/web/SUP01/SUP0122/SUP012201.kmdc
SEMAS_REQUEST_DELAY_SECONDS=1.0

# Gov24 public service Open API.
# GOV24_SERVICE_KEY is issued by data.go.kr and must not be committed.
GOV24_BASE_URL=https://api.odcloud.kr/api
# GOV24_SERVICE_KEY=your-data-go-kr-service-key
GOV24_SERVICE_LIST_USER_TYPE_LIKE=소상공인
GOV24_PAGE_START=1
GOV24_PAGE_SIZE=100
GOV24_MAX_PAGES=200
GOV24_REQUEST_DELAY_SECONDS=0.2
ATTACHMENT_DIR=/app/storage/attachments

LOCAL_DB_PORT=5431
SQL_ECHO=false

# LLM / AI keys. Secrets must not be committed — fill these in your local .env only.
# Gemini is used for the policy-detail AI summary (recommend/explain).
# Without a key the app silently falls back to a rule-based summary (no error).
# GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Google OAuth 2.0 (feat/7 login + calendar).
# Issued in Google Cloud Console; the redirect URI must match the console setting.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
