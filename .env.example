# Copy to .env in the project root before running Docker Compose.
# .env에는 실제 키와 비밀번호가 들어가므로 커밋하지 않습니다.

DB_HOST=db
DB_PORT=5432
DB_NAME=soboksobok
DB_USER=edu
DB_PASSWORD=change-me
LOCAL_DB_PORT=5431
SQL_ECHO=false

# 외부 provider를 선택한 기능에만 해당 키가 필요합니다.
OPENAI_API_KEY=
GEMINI_API_KEY=

# 공통 provider/model 후보입니다.
# provider 허용값: openai | ollama | gemini
# OpenAI chat 예: gpt-4o-mini
# OpenAI embedding 예: text-embedding-3-small (기본 1536차원)
# Ollama chat 예: exaone3.5 또는 로컬에 pull한 기존 chat 모델
# Ollama embedding 예: bge-m3 (1024차원)
# Gemini 모델을 쓸 때는 GEMINI_* 모델명과 실제 출력 차원을 함께 맞추세요.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=exaone3.5
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_DIMENSIONS=1024
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSIONS=768

# 사용자 프로필의 AI 기본 선택은 cloud이며, cloud=OpenAI / local=Ollama입니다.
# [챗봇] 답변 생성과 policy_chunks 검색 임베딩 설정입니다.
# 로컬 전환 예: provider=ollama, LLM_MODEL=exaone3.5,
# EMBEDDING_MODEL=bge-m3, EMBEDDING_DIMENSIONS=1024로 함께 변경합니다.
CHAT_LLM_PROVIDER=openai
CHAT_LLM_MODEL=gpt-4o-mini
# 사용자 프로필의 클라우드 AI/로컬 AI 선택이 각각 아래 모델을 사용합니다.
CHAT_CLOUD_LLM_MODEL=gpt-4o-mini
CHAT_LOCAL_LLM_MODEL=exaone3.5
CHAT_ALLOW_EXTERNAL=true
CHAT_EMBEDDING_PROVIDER=openai
CHAT_EMBEDDING_MODEL=text-embedding-3-small
CHAT_EMBEDDING_DIMENSIONS=1536
# 사용자 전환을 위해 두 벡터를 policy_chunks의 분리 컬럼에 모두 생성합니다.
CHAT_CLOUD_EMBEDDING_MODEL=text-embedding-3-small
CHAT_CLOUD_EMBEDDING_DIMENSIONS=1536
CHAT_LOCAL_EMBEDDING_MODEL=bge-m3
CHAT_LOCAL_EMBEDDING_DIMENSIONS=1024

# [정책 추천] 추천 이유 생성과 rec_vectors 검색 임베딩 설정입니다.
# provider/model/dimensions를 바꾸면 rec_vectors를 반드시 재생성합니다.
RECOMMEND_LLM_PROVIDER=openai
RECOMMEND_LLM_MODEL=gpt-4o-mini
RECOMMEND_CLOUD_LLM_MODEL=gpt-4o-mini
RECOMMEND_LOCAL_LLM_MODEL=exaone3.5
RECOMMEND_ALLOW_EXTERNAL=true
RECOMMEND_EMBEDDING_PROVIDER=openai
RECOMMEND_EMBEDDING_MODEL=text-embedding-3-small
RECOMMEND_EMBEDDING_DIMENSIONS=1536
# rec_vectors에도 클라우드/로컬 벡터를 서로 다른 컬럼에 모두 생성합니다.
RECOMMEND_CLOUD_EMBEDDING_MODEL=text-embedding-3-small
RECOMMEND_CLOUD_EMBEDDING_DIMENSIONS=1536
RECOMMEND_LOCAL_EMBEDDING_MODEL=bge-m3
RECOMMEND_LOCAL_EMBEDDING_DIMENSIONS=1024

# [정책 상세 요약] 전용 호출부가 추가될 때 이 설정과 중앙 factory를 사용합니다.
POLICY_SUMMARY_LLM_PROVIDER=openai
POLICY_SUMMARY_LLM_MODEL=gpt-4o-mini
POLICY_SUMMARY_CLOUD_LLM_MODEL=gpt-4o-mini
POLICY_SUMMARY_LOCAL_LLM_MODEL=exaone3.5
POLICY_SUMMARY_ALLOW_EXTERNAL=true

# [정책 정규화] 규칙으로 확정하지 못한 제출서류/수치 조건의 보조 구조화 설정입니다.
# 기본값은 OpenAI gpt-4o-mini이며, 로컬 전환 시 ollama + exaone3.5 등으로 바꿀 수 있습니다.
NORMALIZATION_LLM_PROVIDER=openai
NORMALIZATION_LLM_MODEL=gpt-4o-mini
NORMALIZATION_ALLOW_EXTERNAL=true
NORMALIZE_LLM_TIMEOUT_SECONDS=30
NORMALIZE_LLM_MAX_CONTEXT_CHARS=800

# [서류검토] 프로필 기본값은 local이며 사용자가 cloud/local을 직접 선택합니다.
# 파일 텍스트 추출은 항상 로컬이고, cloud 선택 시 파싱된 내용이 OpenAI API로 전달됩니다.
DOCUMENT_REVIEW_LLM_PROVIDER=ollama
DOCUMENT_REVIEW_LLM_MODEL=exaone3.5
DOCUMENT_REVIEW_EMBEDDING_PROVIDER=ollama
DOCUMENT_REVIEW_EMBEDDING_MODEL=bge-m3
DOCUMENT_REVIEW_EMBEDDING_DIMENSIONS=1024
DOCUMENT_REVIEW_CLOUD_LLM_MODEL=gpt-4o-mini
DOCUMENT_REVIEW_LOCAL_LLM_MODEL=exaone3.5
DOCUMENT_REVIEW_CLOUD_EMBEDDING_MODEL=text-embedding-3-small
DOCUMENT_REVIEW_CLOUD_EMBEDDING_DIMENSIONS=1536
DOCUMENT_REVIEW_LOCAL_EMBEDDING_MODEL=bge-m3
DOCUMENT_REVIEW_LOCAL_EMBEDDING_DIMENSIONS=1024

# [서류 발급 가이드] 공유 가이드는 OpenAI/Ollama 두 벡터를 모두 미리 생성합니다.
# 캘린더 코치 검색 시 사용자의 cloud/local 설정과 같은 컬럼을 사용합니다.
PREP_EMBEDDING_PROVIDER=ollama
PREP_EMBEDDING_MODEL=bge-m3
PREP_EMBEDDING_DIMENSIONS=1024
PREP_ALLOW_EXTERNAL=true
PREP_CLOUD_EMBEDDING_MODEL=text-embedding-3-small
PREP_CLOUD_EMBEDDING_DIMENSIONS=1536
PREP_LOCAL_EMBEDDING_MODEL=bge-m3
PREP_LOCAL_EMBEDDING_DIMENSIONS=1024
# 서류 원문 진단은 일반 채팅보다 길 수 있어 별도 제한시간을 둡니다.
REVIEW_LLM_TIMEOUT_SECONDS=180

# [캘린더 AI 코치] 일반 캘린더 조회/등록 CRUD에는 LLM을 사용하지 않습니다.
# AI 코칭만 이 설정을 사용하며 openai/ollama/gemini 중 원하는 provider로 변경할 수 있습니다.
CALENDAR_COACH_LLM_PROVIDER=openai
CALENDAR_COACH_LLM_MODEL=gpt-4o-mini
CALENDAR_COACH_CLOUD_LLM_MODEL=gpt-4o-mini
CALENDAR_COACH_LOCAL_LLM_MODEL=exaone3.5
CALENDAR_COACH_ALLOW_EXTERNAL=true

# 모델 호출 로그는 한 줄 메타데이터만 남깁니다. 원문/응답/벡터/파일명/키는 출력하지 않습니다.
# 공통 채팅·임베딩 호출 제한시간입니다. 정규화/서류검토처럼 기능별 timeout을 넘기는 호출은 해당 값이 우선합니다.
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_EMBEDDING_TIMEOUT_SECONDS=60
LLM_CALL_LOGGING_ENABLED=true
LLM_LOG_LEVEL=INFO
LLM_LOG_CONTENT=false
LLM_LOG_PREVIEW_CHARS=0

# 챗봇 청킹/검색 설정
CHAT_CHUNK_SIZE=280
CHAT_CHUNK_OVERLAP=40
CHAT_MIN_CHUNK_SIZE=80
CHAT_NEIGHBOR_CHUNK_WINDOW=1
CHAT_RETRIEVAL_LIMIT=6
CHAT_MAX_CONTEXT_CHARS=4500
EMBED_CHAT_CHUNKS_AFTER_NORMALIZE=true

# 첨부파일/서류 파싱은 kordoc 및 로컬 라이브러리로 처리합니다.
ATTACHMENT_DIR=/app/storage/attachments
REVIEW_UPLOAD_DIR=/app/storage/review_uploads
KORDOC_CMD=kordoc
KORDOC_TIMEOUT_SECONDS=120
EXTRACT_MAX_CHARS=1000000
EXTRACT_RETRY_FAILED=false
EXTRACT_BATCH_LIMIT=0

# Google OAuth / frontend
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Crawler / public data
CRAWL_INTERVAL_SECONDS=86400
SBIZ24_PAGE_SIZE=100
SBIZ24_REQUEST_DELAY_SECONDS=1.0
SEMAS_SEED_URL=https://www.semas.or.kr/web/SUP01/SUP0122/SUP012201.kmdc
SEMAS_REQUEST_DELAY_SECONDS=1.0
GOV24_BASE_URL=https://api.odcloud.kr/api
GOV24_SERVICE_KEY=
GOV24_SERVICE_LIST_USER_TYPE_LIKE=소상공인
GOV24_PAGE_START=1
GOV24_PAGE_SIZE=100
GOV24_MAX_PAGES=200
GOV24_REQUEST_DELAY_SECONDS=0.2

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=soboksobok-chatbot-rag
