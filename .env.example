# Copy this file to .env in the project root before running Docker Compose.
# Do not commit .env.

DB_HOST=db
DB_PORT=5432
DB_NAME=soboksobok
DB_USER=edu
DB_PASSWORD=change-me

CRAWL_INTERVAL_SECONDS=86400
SBIZ24_PAGE_SIZE=100
SBIZ24_REQUEST_DELAY_SECONDS=1.0
SEMAS_SEED_URL=https://www.semas.or.kr/web/SUP01/SUP0122/SUP012201.kmdc
SEMAS_REQUEST_DELAY_SECONDS=1.0

# Gov24 public service Open API.
# GOV24_SERVICE_KEY is issued by data.go.kr and must not be committed.
GOV24_BASE_URL=https://api.odcloud.kr/api

# GOV24_SERVICE_KEY=your-data-go-kr-service-key
GOV24_SERVICE_LIST_USER_TYPE_LIKE=소상공인
GOV24_PAGE_START=1
GOV24_PAGE_SIZE=100
GOV24_MAX_PAGES=200
GOV24_REQUEST_DELAY_SECONDS=0.2
ATTACHMENT_DIR=/app/storage/attachments

LOCAL_DB_PORT=5431
SQL_ECHO=false

# ─────────────────────────────────────────────────────────────
# 아래 키들은 팀장에게 값을 받아 채워 넣으세요. .env는 절대 커밋하지 않습니다.
# 값이 비어 있으면 해당 기능이 동작하지 않습니다.
# ─────────────────────────────────────────────────────────────

# [필수] 구글 로그인. 없으면 로그인 자체가 안 되고 앱을 쓸 수 없습니다.
# 리다이렉트 URI(http://localhost:8000/api/v1/auth/google/callback)는 콘솔에 이미 등록돼 있어
# 각자 localhost에서 그대로 동작합니다. 별도 등록이 필요 없습니다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [필수] 챗봇 답변 생성 (gpt-4o-mini). 없으면 챗봇이 답을 못 만듭니다.
OPENAI_API_KEY=

# [선택] 정책 상세 AI 요약. 없으면 규칙 기반 요약으로 조용히 폴백합니다(에러 아님).
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# [선택] 정부24 공공데이터 크롤링. 없으면 해당 소스만 수집이 안 됩니다.
GOV24_SERVICE_KEY=

# 로컬 Ollama (임베딩 bge-m3 + 서류검토 LLM exaone3.5).
# 컨테이너에서 호스트의 Ollama를 부르는 주소라 보통 그대로 두면 됩니다.
OLLAMA_BASE_URL=http://host.docker.internal:11434
